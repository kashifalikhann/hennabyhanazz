---
const { lang = 'en' } = Astro.props;
const isEs = lang === 'es';
const instagramUrl = import.meta.env.PUBLIC_INSTAGRAM_URL || 'https://instagram.com/hennabyhanazz';

const t = (key: string) => {
  const translations: Record<string, Record<string, string>> = {
    en: { 'gallery.title': 'Our Work', 'gallery.subtitle': 'Every design is unique. Browse a selection of recent work.', 'gallery.follow': 'Follow @hennabyhanazz on Instagram' },
    es: { 'gallery.title': 'Nuestro Trabajo', 'gallery.subtitle': 'Cada diseño es único. Explora una selección de trabajos recientes.', 'gallery.follow': 'Sigue a @hennabyhanazz en Instagram' }
  };
  return translations[lang]?.[key] || key;
};

// Curated henna images (replace with artist's actual photos)
const galleryImages = [
  { src: 'https://images.unsplash.com/photo-1590012314607-20e25d5ad998?w=600&q=80', alt: 'Intricate bridal henna design' },
  { src: 'https://images.unsplash.com/photo-1611162617474-5b21e879e113?w=600&q=80', alt: 'Henna hands detail' },
  { src: 'https://images.unsplash.com/photo-1524504388940-b1c1722653e1?w=600&q=80', alt: 'Henna artist at work' },
  { src: 'https://images.unsplash.com/photo-1609220136736-443140cffec6?w=600&q=80', alt: 'Beautiful henna patterns' },
  { src: 'https://images.unsplash.com/photo-1544717297-fa95b6ee9643?w=600&q=80', alt: 'Henna workshop' },
  { src: 'https://images.unsplash.com/photo-1519741497674-611481863552?w=600&q=80', alt: 'Wedding henna celebration' },
];
---

<section id="gallery" class="section-padding bg-cream">
  <div class="container-premium">
    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-12">
      <span class="eyebrow fade-up">Portfolio</span>
      <h2 class="section-title fade-up stagger-1">{t('gallery.title')}</h2>
      <p class="section-subtitle mx-auto fade-up stagger-2">{t('gallery.subtitle')}</p>
    </div>

    <!-- Gallery Grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4 lg:gap-6">
      {galleryImages.map((img, i) => (
        <div class={`relative aspect-square rounded-xl overflow-hidden group cursor-pointer fade-up`} style={`transition-delay: ${i * 0.08}s`}>
          <img
            src={img.src}
            alt={img.alt}
            class="img-cover transition-transform duration-700 group-hover:scale-110"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-charcoal/0 group-hover:bg-charcoal/20 transition-colors duration-300"></div>
        </div>
      ))}
    </div>

    <!-- Instagram CTA -->
    <div class="text-center mt-10 fade-up">
      <a
        href={instagramUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm font-medium text-charcoal-light hover:text-gold-dark transition-colors"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <circle cx="12" cy="12" r="5"/>
          <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/>
        </svg>
        {t('gallery.follow')} →
      </a>
    </div>
  </div>
</section>
