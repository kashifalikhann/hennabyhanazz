---
const { lang = 'en' } = Astro.props;
const isEs = lang === 'es';
const t = (key: string) => {
  const translations: Record<string, Record<string, string>> = {
    en: {
      'about.eyebrow': 'The Artist',
      'about.title': 'Henna mastery, Barcelona soul',
      'about.p1': 'Hanazz is a professional henna artist based in Barcelona, bringing expertise across Pakistani, Arabic, Indian and fusion styles. With a commitment to 100% natural, PPD-free henna, every design is safe, stunning and deeply personal.',
      'about.p2': 'From bridal mehndi for destination weddings to intimate private sessions and large-scale celebrations, Hanazz works with each client to create something uniquely theirs.',
      'about.quote': '"Every line tells a story. My job is to make yours beautiful."',
      'about.services_label': 'Services include:',
      'about.service_1': 'Bridal & wedding henna',
      'about.service_2': 'Event & party henna',
      'about.service_3': 'Private sessions',
      'about.service_4': 'Henna workshops',
      'about.service_5': 'Event decorations',
    },
    es: {
      'about.eyebrow': 'La Artista',
      'about.title': 'Maestría en henna, alma de Barcelona',
      'about.p1': 'Hanazz es una artista profesional de henna con sede en Barcelona, con experiencia en estilos pakistaní, árabe, indio y fusión. Comprometida con la henna 100% natural y libre de PPD, cada diseño es seguro, impresionante y profundamente personal.',
      'about.p2': 'Desde mehndi nupcial para bodas de destino hasta sesiones privadas íntimas y celebraciones a gran escala, Hanazz trabaja con cada cliente para crear algo único.',
      'about.quote': '"Cada línea cuenta una historia. Mi trabajo es hacer la tuya hermosa."',
      'about.services_label': 'Los servicios incluyen:',
      'about.service_1': 'Henna nupcial y para bodas',
      'about.service_2': 'Henna para eventos y fiestas',
      'about.service_3': 'Sesiones privadas',
      'about.service_4': 'Talleres de henna',
      'about.service_5': 'Decoración de eventos',
    }
  };
  return translations[lang]?.[key] || key;
};

const services = [
  t('about.service_1'),
  t('about.service_2'),
  t('about.service_3'),
  t('about.service_4'),
  t('about.service_5'),
];
---

<section id="about" class="section-padding bg-cream">
  <div class="container-premium">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">

      <!-- Image -->
      <div class="relative fade-up">
        <div class="relative aspect-[3/4] rounded-2xl overflow-hidden shadow-xl">
          <img
            src="/images/gallery/Imagen_Stand_Henna.jpg"
            alt={isEs ? 'Hanazz, artista profesional de henna en Barcelona' : 'Hanazz, professional henna artist in Barcelona'}
            class="img-cover"
            loading="lazy"
          />
        </div>
        <!-- Accent element -->
        <div class="absolute -bottom-4 -right-4 w-32 h-32 bg-gold-muted rounded-2xl -z-10"></div>
      </div>

      <!-- Content -->
      <div class="max-w-lg">
        <span class="eyebrow fade-up">{t('about.eyebrow')}</span>
        <h2 class="section-title fade-up stagger-1">{t('about.title')}</h2>

        <p class="text-gray leading-relaxed mb-6 fade-up stagger-2">
          {t('about.p1')}
        </p>

        <p class="text-gray leading-relaxed mb-8 fade-up stagger-2">
          {t('about.p2')}
        </p>

        <!-- Quote -->
        <blockquote class="border-l-2 border-gold pl-6 py-2 mb-8 fade-up stagger-3">
          <p class="font-display text-lg italic text-charcoal-light">
            {t('about.quote')}
          </p>
        </blockquote>

        <!-- Services list -->
        <div class="fade-up stagger-4">
          <p class="text-sm font-semibold text-charcoal mb-3">{t('about.services_label')}</p>
          <div class="flex flex-wrap gap-2">
            {services.map((service) => (
              <span class="inline-block px-4 py-1.5 rounded-full text-sm font-medium bg-gold-muted text-gold-dark">
                {service}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
