---
const { lang = 'en' } = Astro.props;
const isEs = lang === 'es';
const t = (key: string) => {
  const translations: Record<string, Record<string, string>> = {
    en: {
      'hero.eyebrow': 'Professional Henna Artist',
      'hero.title': 'Henna By Hanazz',
      'hero.subtitle': '100% natural henna artistry in the heart of Barcelona. Pakistani, Arabic, Indian & fusion styles — for brides, events and private sessions.',
      'hero.cta_primary': 'Book via WhatsApp',
      'hero.cta_secondary': 'View Our Work',
      'hero.badge_1': '100% Natural · PPD Free',
      'hero.badge_2': 'Bridal · Events · Private',
      'hero.badge_3': 'Barcelona & Destination',
    },
    es: {
      'hero.eyebrow': 'Artista Profesional de Henna',
      'hero.title': 'Henna By Hanazz',
      'hero.subtitle': 'Henna 100% natural en el corazón de Barcelona. Estilos pakistaní, árabe, indio y fusión — para novias, eventos y sesiones privadas.',
      'hero.cta_primary': 'Reservar por WhatsApp',
      'hero.cta_secondary': 'Ver Trabajos',
      'hero.badge_1': '100% Natural · Sin PPD',
      'hero.badge_2': 'Novias · Eventos · Privado',
      'hero.badge_3': 'Barcelona y Destino',
    }
  };
  return translations[lang]?.[key] || key;
};

const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER || '34655729113';
const whatsappLink = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(isEs ? 'Hola, me gustaría reservar una sesión de henna' : 'Hello, I would like to book a henna session')}`;
const basePath = isEs ? '/es' : '';
---

<section class="relative min-h-[90vh] flex items-center overflow-hidden bg-cream">
  <!-- Background decorative elements -->
  <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-gold-muted to-transparent opacity-40"></div>
  <div class="absolute bottom-0 left-0 w-1/3 h-2/3 bg-gradient-to-tr from-terracotta-muted to-transparent opacity-30"></div>

  <div class="container-premium relative z-10">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Left: Text Content -->
      <div class="max-w-xl">
        <span class="eyebrow fade-up">{t('hero.eyebrow')}</span>

        <h1 class="font-display text-5xl md:text-6xl lg:text-7xl font-semibold text-charcoal mb-6 fade-up stagger-1 leading-[1.1]">
          {t('hero.title')}
        </h1>

        <p class="text-lg md:text-xl text-gray leading-relaxed mb-8 fade-up stagger-2">
          {t('hero.subtitle')}
        </p>

        <div class="flex flex-wrap gap-4 mb-10 fade-up stagger-3">
          <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="btn-whatsapp text-base">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            {t('hero.cta_primary')}
          </a>
          <a href={`${basePath}/#gallery`} class="btn-outline text-base">
            {t('hero.cta_secondary')}
          </a>
        </div>

        <!-- Trust badges -->
        <div class="flex flex-wrap gap-4 text-xs font-medium text-gray-light fade-up stagger-4">
          <span class="flex items-center gap-1.5">
            <span class="w-1.5 h-1.5 rounded-full bg-gold"></span>
            {t('hero.badge_1')}
          </span>
          <span class="flex items-center gap-1.5">
            <span class="w-1.5 h-1.5 rounded-full bg-gold"></span>
            {t('hero.badge_2')}
          </span>
          <span class="flex items-center gap-1.5">
            <span class="w-1.5 h-1.5 rounded-full bg-gold"></span>
            {t('hero.badge_3')}
          </span>
        </div>
      </div>

      <!-- Right: Hero Image -->
      <div class="relative fade-up stagger-2">
        <div class="relative aspect-[4/5] rounded-2xl overflow-hidden shadow-2xl">
          <!-- Placeholder: Replace with actual henna photo -->
          <img
            src="/images/gallery/469531126_18344098489181880_4335127524695816281_n.jpeg"
            alt="Intricate bridal henna design by Henna By Hanazz"
            class="img-cover"
            loading="eager"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-charcoal/20 to-transparent"></div>
        </div>

        <!-- Floating accent card -->
        <div class="absolute -bottom-6 -left-6 bg-white rounded-xl p-4 shadow-lg border border-border max-w-[200px]">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-gold-muted flex items-center justify-center">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#C9A96E" stroke-width="2">
                <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-charcoal">100% Natural</p>
              <p class="text-xs text-gray-light">PPD Free · Organic</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
