---
import { images } from '../../lib/images';
const { lang = 'en' } = Astro.props;
const isEs = lang === 'es';
---

<section id="experience" class="py-16 md:py-24 lg:py-28 px-6 relative overflow-hidden">
  <div class="absolute inset-0 opacity-[0.02]" style="background-image: radial-gradient(circle at 50% 50%, var(--color-gold) 1px, transparent 1px); background-size: 40px 40px;"></div>

  <div class="max-w-6xl mx-auto relative">
    <div class="grid md:grid-cols-2 gap-8 md:gap-16 items-center">
      <div class="relative order-2 md:order-1">
        <div class="double-bezel">
          <div class="double-bezel-inner aspect-[16/10] overflow-hidden">
            <img
              src={images.experience.src}
              alt={images.experience.alt}
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
        <div class="absolute -top-4 -left-4 w-32 h-32 rounded-full bg-terracotta/10 -z-10 blur-3xl"></div>
        <p class="text-[10px] text-muted/50 text-left mt-2">
          {isEs ? 'Foto por' : 'Photo by'} <a href={images.experience.creditUrl} target="_blank" rel="noopener noreferrer" class="underline hover:text-gold transition-colors">{images.experience.credit}</a> {isEs ? 'en Pexels' : 'on Pexels'}
        </p>
      </div>

      <div class="space-y-6 order-1 md:order-2">
        <span class="eyebrow">{isEs ? 'La Experiencia' : 'The Experience'}</span>
        <h2 class="font-display text-4xl md:text-6xl font-bold tracking-tight">
          {isEs ? 'Mas que henna' : 'More than henna'}
        </h2>
        <div class="w-12 h-0.5 bg-gold"></div>
        <p class="text-muted leading-relaxed text-lg">
          {isEs
            ? 'Entra en nuestro estudio en el Barrio Gotico. El aroma del aceite de eucalipto, las velas parpadeando, la musica suave. Este no es solo un servicio de henna — es un ritual de cuidado personal.'
            : 'Step into our Gothic Quarter studio. The scent of eucalyptus oil, flickering candles, soft music. This is not just a henna service — it is a self-care ritual.'}
        </p>
        <p class="text-muted leading-relaxed">
          {isEs
            ? 'Toda nuestra henna es 100% natural, importada directamente de productores tradicionales y mezclada a mano con aceites esenciales. Sin PPD, sin quimicos, sin aditivos — solo la planta Lawsonia inermis pura, como se ha hecho durante siglos en Lahore y el subcontinente.'
            : 'All our henna is 100% natural, sourced directly from traditional growers and hand-mixed with essential oils. No PPD, no chemicals, no additives — just pure Lawsonia inermis plant, as it has been made for centuries in Lahore and the subcontinent.'}
        </p>
        <ul class="space-y-3 text-muted">
          <li class="flex items-center gap-3">
            <span class="w-1.5 h-1.5 rounded-full bg-gold shrink-0"></span>
            {isEs ? 'Ambiente sereno y privado' : 'Serene, private setting'}
          </li>
          <li class="flex items-center gap-3">
            <span class="w-1.5 h-1.5 rounded-full bg-gold shrink-0"></span>
            {isEs ? 'Henna 100% natural, libre de PPD' : '100% natural, PPD-free henna'}
          </li>
          <li class="flex items-center gap-3">
            <span class="w-1.5 h-1.5 rounded-full bg-gold shrink-0"></span>
            {isEs ? 'Mezclada a mano con aceites esenciales' : 'Hand-mixed with essential oils'}
          </li>
          <li class="flex items-center gap-3">
            <span class="w-1.5 h-1.5 rounded-full bg-gold shrink-0"></span>
            {isEs ? 'Atencion personalizada en cada diseno' : 'Personalized attention to every design'}
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>
