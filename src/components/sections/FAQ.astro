---
const { lang = 'en' } = Astro.props;
const isEs = lang === 'es';
const t = (key: string) => {
  const translations: Record<string, Record<string, string>> = {
    en: {
      'faq.eyebrow': 'FAQ',
      'faq.title': 'Frequently Asked Questions',
      'faq.q1.q': 'What styles of henna do you offer?',
      'faq.q1.a': 'I specialise in Pakistani, Arabic, Indian and fusion styles. Every design is custom-created based on your preference and the style that suits you best.',
      'faq.q2.q': 'Is your henna safe?',
      'faq.q2.a': 'Absolutely. I use 100% natural henna with no PPD, no chemicals and no additives. It\'s safe for all skin types.',
      'faq.q3.q': 'Do you travel to the client?',
      'faq.q3.a': 'Yes, I offer home service throughout Barcelona and the surrounding area. I also travel for destination weddings.',
      'faq.q4.q': 'How far in advance should I book bridal henna?',
      'faq.q4.a': 'I recommend booking at least 2-3 months in advance for bridal work, especially during wedding season.',
      'faq.q5.q': 'Do you offer henna for events?',
      'faq.q5.a': 'Yes, I provide live henna stations for weddings, parties, corporate events and cultural celebrations.',
      'faq.q6.q': 'How do I book and pay?',
      'faq.q6.a': 'You can book directly via WhatsApp. Payment can be made via Bizum, bank transfer or cash.',
    },
    es: {
      'faq.eyebrow': 'FAQ',
      'faq.title': 'Preguntas Frecuentes',
      'faq.q1.q': '¿Qué estilos de henna ofrecéis?',
      'faq.q1.a': 'Me especializo en estilos pakistaní, árabe, indio y fusión. Cada diseño se crea a medida según tus preferencias y el estilo que mejor se adapte a ti.',
      'faq.q2.q': '¿Es segura vuestra henna?',
      'faq.q2.a': 'Absolutamente. Utilizo henna 100% natural sin PPD, sin químicos y sin aditivos. Es segura para todo tipo de piel.',
      'faq.q3.q': '¿Viajáis al domicilio del cliente?',
      'faq.q3.a': 'Sí, ofrezco servicio a domicilio en Barcelona y alrededores. También viajo para bodas de destino.',
      'faq.q4.q': '¿Con cuánta antelación debo reservar la henna nupcial?',
      'faq.q4.a': 'Recomiendo reservar con al menos 2-3 meses de antelación para trabajos nupciales, especialmente en temporada de bodas.',
      'faq.q5.q': '¿Ofrecéis henna para eventos?',
      'faq.q5.a': 'Sí, ofrezco estaciones de henna en vivo para bodas, fiestas, eventos corporativos y celebraciones culturales.',
      'faq.q6.q': '¿Cómo reservo y pago?',
      'faq.q6.a': 'Puedes reservar directamente por WhatsApp. El pago puede ser mediante Bizum, transferencia bancana o efectivo.',
    }
  };
  return translations[lang]?.[key] || key;
};

const faqs = [
  { qKey: 'faq.q1.q', aKey: 'faq.q1.a' },
  { qKey: 'faq.q2.q', aKey: 'faq.q2.a' },
  { qKey: 'faq.q3.q', aKey: 'faq.q3.a' },
  { qKey: 'faq.q4.q', aKey: 'faq.q4.a' },
  { qKey: 'faq.q5.q', aKey: 'faq.q5.a' },
  { qKey: 'faq.q6.q', aKey: 'faq.q6.a' },
];
---

<section id="faq" class="section-padding bg-white">
  <div class="container-premium">
    <div class="max-w-3xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-12">
        <span class="eyebrow fade-up">{t('faq.eyebrow')}</span>
        <h2 class="section-title fade-up stagger-1">{t('faq.title')}</h2>
      </div>

      <!-- FAQ Items -->
      <div class="divide-y divide-border">
        {faqs.map((faq, i) => (
          <div class="faq-item fade-up" style={`transition-delay: ${i * 0.05}s`}>
            <button
              class="faq-question"
              onclick="this.nextElementSibling.classList.toggle('open'); this.querySelector('span').textContent = this.nextElementSibling.classList.contains('open') ? '−' : '+'"
            >
              <span>{t(faq.qKey)}</span>
              <span class="text-gold text-xl shrink-0">+</span>
            </button>
            <div class="faq-answer">
              {t(faq.aKey)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
