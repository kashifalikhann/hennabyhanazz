---
const { lang = 'en', whatsappNumber, instagramUrl, contactEmail } = Astro.props;
const isEs = lang === 'es';
const t = (key: string) => {
  const translations: Record<string, Record<string, string>> = {
    en: {
      'cta.title': 'Ready to create something beautiful?',
      'cta.subtitle': 'Get in touch for a personalised quote or to check availability.',
      'cta.whatsapp': 'WhatsApp Us',
      'cta.instagram': 'Follow on Instagram',
      'cta.bizum_label': 'Or pay via Bizum:',
      'cta.bizum_number': '+34 655 729 113',
      'footer.tagline': 'Professional Henna Artist, Barcelona',
      'footer.services': 'Services',
      'footer.connect': 'Connect',
      'footer.legal': 'Legal',
      'footer.privacy': 'Privacy Policy',
      'footer.cookies': 'Cookie Policy',
      'footer.copyright': '© 2025 Henna By Hanazz. All rights reserved.',
    },
    es: {
      'cta.title': '¿Lista para crear algo hermoso?',
      'cta.subtitle': 'Ponte en contacto para un presupuesto personalizado o para consultar disponibilidad.',
      'cta.whatsapp': 'Escríbenos por WhatsApp',
      'cta.instagram': 'Síguenos en Instagram',
      'cta.bizum_label': 'O paga por Bizum:',
      'cta.bizum_number': '+34 655 729 113',
      'footer.tagline': 'Artista Profesional de Henna, Barcelona',
      'footer.services': 'Servicios',
      'footer.connect': 'Conecta',
      'footer.legal': 'Legal',
      'footer.privacy': 'Política de Privacidad',
      'footer.cookies': 'Política de Cookies',
      'footer.copyright': '© 2025 Henna By Hanazz. Todos los derechos reservados.',
    }
  };
  return translations[lang]?.[key] || key;
};

const base = '/hennabyhanazz';
const whatsappLink = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(isEs ? 'Hola, me gustaría reservar una sesión de henna' : 'Hello, I would like to book a henna session')}`;
const basePath = isEs ? `${base}es` : base;
---

<!-- CTA Section -->
<section class="section-padding bg-charcoal text-white relative overflow-hidden">
  <div class="absolute inset-0 pattern-overlay opacity-20"></div>
  <div class="container-premium relative z-10">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-semibold mb-6 fade-up">
        {t('cta.title')}
      </h2>
      <p className="text-lg text-white/70 mb-10 fade-up stagger-1">
        {t('cta.subtitle')}
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-10 fade-up stagger-2">
        <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="btn-whatsapp text-base justify-center">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          {t('cta.whatsapp')}
        </a>
        <a href={instagramUrl} target="_blank" rel="noopener noreferrer" class="btn-outline border-white/30 text-white hover:bg-white hover:text-charcoal justify-center">
          {t('cta.instagram')}
        </a>
      </div>

      <!-- Bizum -->
      <div class="text-sm text-white/50 fade-up stagger-3">
        <p className="mb-1">{t('cta.bizum_label')}</p>
        <p className="font-mono text-white/80 text-base tracking-wider">{t('cta.bizum_number')}</p>
      </div>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="bg-charcoal text-white/60 py-12 border-t border-white/5">
  <div class="container-premium">
    <div class="grid md:grid-cols-4 gap-8 mb-12">
      <!-- Brand -->
      <div class="md:col-span-1">
        <a href={`${basePath || '/'}`} class="font-display text-2xl font-semibold text-white no-underline">
          Henna<span className="text-gold">.</span>
        </a>
        <p class="text-sm mt-3 text-white/40">{t('footer.tagline')}</p>
      </div>

      <!-- Services -->
      <div>
        <h4 className="text-xs font-semibold uppercase tracking-wider text-white/30 mb-4">{t('footer.services')}</h4>
        <ul className="space-y-2 text-sm">
          <li><a href={`${basePath}/#services`} className="hover:text-white transition-colors">{isEs ? 'Henna Nupcial' : 'Bridal Henna'}</a></li>
          <li><a href={`${basePath}/#services`} className="hover:text-white transition-colors">{isEs ? 'Eventos y Fiestas' : 'Events & Parties'}</a></li>
          <li><a href={`${basePath}/#services`} className="hover:text-white transition-colors">{isEs ? 'Sesiones Privadas' : 'Private Sessions'}</a></li>
          <li><a href={`${basePath}/#services`} className="hover:text-white transition-colors">{isEs ? 'Talleres' : 'Workshops'}</a></li>
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <h4 className="text-xs font-semibold uppercase tracking-wider text-white/30 mb-4">{t('footer.connect')}</h4>
        <ul className="space-y-2 text-sm">
          <li><a href={instagramUrl} target="_blank" rel="noopener noreferrer" className="hover:text-white transition-colors">Instagram</a></li>
          <li><a href={whatsappLink} target="_blank" rel="noopener noreferrer" className="hover:text-white transition-colors">WhatsApp</a></li>
          {contactEmail && <li><a href={`mailto:${contactEmail}`} className="hover:text-white transition-colors">Email</a></li>}
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 className="text-xs font-semibold uppercase tracking-wider text-white/30 mb-4">{t('footer.legal')}</h4>
        <ul className="space-y-2 text-sm">
          <li><a href={`${basePath}/privacy`} className="hover:text-white transition-colors">{t('footer.privacy')}</a></li>
          <li><a href={`${basePath}/cookies`} className="hover:text-white transition-colors">{t('footer.cookies')}</a></li>
        </ul>
      </div>
    </div>

    <!-- Copyright -->
    <div class="border-t border-white/5 pt-8 text-center text-xs text-white/30">
      {t('footer.copyright')}
    </div>
  </div>
</footer>
