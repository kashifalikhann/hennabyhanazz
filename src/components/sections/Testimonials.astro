---
const { lang = 'en' } = Astro.props;
const isEs = lang === 'es';
const t = (key: string) => {
  const translations: Record<string, Record<string, string>> = {
    en: {
      'testimonials.eyebrow': 'Testimonials',
      'testimonials.title': 'What our clients say',
      'testimonials.t1.text': 'Hanazz made my bridal henna absolutely beautiful. The design was exactly what I wanted and she was so professional throughout.',
      'testimonials.t1.name': 'Sarah M.',
      'testimonials.t1.role': 'Bride, Barcelona',
      'testimonials.t2.text': 'We hired Hanazz for our wedding guests and everyone loved it. She was fast, gentle and the designs were stunning.',
      'testimonials.t2.name': 'Amira K.',
      'testimonials.t2.role': 'Wedding, Costa Brava',
      'testimonials.t3.text': 'The workshop was incredible. Hanazz is a patient teacher and I learned so much in just one session.',
      'testimonials.t3.name': 'Laura R.',
      'testimonials.t3.role': 'Workshop, Barcelona',
      'testimonials.note': 'More reviews coming soon. Be the first to leave yours!',
    },
    es: {
      'testimonials.eyebrow': 'Testimonios',
      'testimonials.title': 'Lo que dicen nuestras clientas',
      'testimonials.t1.text': 'Hanazz hizo mi henna nupcial absolutamente hermosa. El diseño era exactamente lo que quería y fue muy profesional en todo momento.',
      'testimonials.t1.name': 'Sarah M.',
      'testimonials.t1.role': 'Novia, Barcelona',
      'testimonials.t2.text': 'Contratamos a Hanazz para las invitadas de nuestra boda y a todas les encantó. Fue rápida, delicada y los diseños fueron impresionantes.',
      'testimonials.t2.name': 'Amira K.',
      'testimonials.t2.role': 'Boda, Costa Brava',
      'testimonials.t3.text': 'El taller fue increíble. Hanazz es una profesora paciente y aprendí mucho en una sola sesión.',
      'testimonials.t3.name': 'Laura R.',
      'testimonials.t3.role': 'Taller, Barcelona',
      'testimonials.note': 'Más reseñas próximamente. ¡Sé la primera en dejar la tuya!',
    }
  };
  return translations[lang]?.[key] || key;
};

const testimonials = [
  {
    textKey: 'testimonials.t1.text',
    nameKey: 'testimonials.t1.name',
    roleKey: 'testimonials.t1.role',
  },
  {
    textKey: 'testimonials.t2.text',
    nameKey: 'testimonials.t2.name',
    roleKey: 'testimonials.t2.role',
  },
  {
    textKey: 'testimonials.t3.text',
    nameKey: 'testimonials.t3.name',
    roleKey: 'testimonials.t3.role',
  },
];
---

<section class="section-padding bg-cream">
  <div class="container-premium">
    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="eyebrow fade-up">{t('testimonials.eyebrow')}</span>
      <h2 class="section-title fade-up stagger-1">{t('testimonials.title')}</h2>
    </div>

    <!-- Testimonials Grid -->
    <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
      {testimonials.map((item, i) => (
        <div class={`testimonial-card fade-up stagger-${i + 1}`}>
          <div class="testimonial-stars">★★★★★</div>
          <p class="text-charcoal-light leading-relaxed mb-6 text-[0.95rem]">
            "{t(item.textKey)}"
          </p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-gold-muted flex items-center justify-center">
              <span class="text-sm font-semibold text-gold-dark">
                {t(item.nameKey).charAt(0)}
              </span>
            </div>
            <div>
              <p className="text-sm font-semibold text-charcoal">{t(item.nameKey)}</p>
              <p className="text-xs text-gray-light">{t(item.roleKey)}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <p class="text-center text-sm text-gray-light mt-8 fade-up">
      {t('testimonials.note')}
    </p>
  </div>
</section>
