---
const { lang = 'en' } = Astro.props;
const isEs = lang === 'es';
const testimonials = [
  { name: 'Sofia R.', text: isEs ? 'Hanazz hizo la henna para mi boda en el Born — un diseno de brazo completo con motivos florales Mughal. Duro 16 dias y quedo increible en las fotos. Todavia me preguntan donde la hice.' : 'Hanazz did my wedding henna in El Born — a full arm design with Mughal floral motifs. It lasted 16 days and looked stunning in photos. People still ask where I got it done.', rating: 5 },
  { name: 'James T.', text: isEs ? 'Lleve a mi equipo corporativo a un taller de henna con Hanazz como actividad de team building. Profesional, paciente y adapto los disenos al gusto de cada uno. Repetiremos el ano que viene.' : 'I took my corporate team to a henna workshop with Hanazz as a team building activity. Professional, patient, and tailored designs to everyone\'s taste. We are booking again next year.', rating: 5 },
  { name: 'Maria L.', text: isEs ? 'Asisti a su taller de iniciacion y en dos horas ya estaba haciendo mis primeros diseños basicos. Hanazz explica con claridad y mucha paciencia. Sali con henna puesta y muchas ganas de seguir practicando.' : 'I attended her beginner workshop and within two hours I was doing my first basic designs. Hanazz explains clearly and with so much patience. I left with henna on and eager to keep practicing.', rating: 5 },
  { name: 'Alex K.', text: isEs ? 'Encargue un diseno personalizado de media pierna inspirando en la Alhambra. Hanazz capturo cada detalle — los arabescos, la simetria, todo. Duro casi tres semanas. Una obra de arte.' : 'I ordered a custom half-leg design inspired by the Alhambra. Hanazz captured every detail — the arabesques, the symmetry, everything. It lasted almost three weeks. A work of art.', rating: 5 },
];
---

<section id="testimonials" class="py-16 md:py-24 lg:py-28 px-6">
  <div class="max-w-4xl mx-auto text-center">
    <span class="eyebrow">{isEs ? 'Testimonios' : 'Testimonials'}</span>
    <h2 class="font-display text-3xl sm:text-4xl md:text-6xl font-bold tracking-tight mt-4 mb-12 md:mb-16">
      {isEs ? 'Lo Que Dicen Nuestros Clientes' : 'What Our Clients Say'}
    </h2>

    <div class="grid md:grid-cols-2 gap-4 md:gap-6" id="testimonial-grid">
      {testimonials.map((t, i) => (
        <div class="double-bezel" style={`transition-delay: ${i * 100}ms`}>
          <div class="double-bezel-inner bg-surface p-4 md:p-6 lg:p-8 text-left">
            <div class="flex gap-1 mb-4">
              {Array.from({ length: t.rating }).map(() => (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#C9A96E" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              ))}
            </div>
            <p class="text-muted leading-relaxed mb-4 italic">"{t.text}"</p>
            <p class="font-display font-semibold text-sm">{t.name}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
