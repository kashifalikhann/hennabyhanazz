---
const { lang = 'en' } = Astro.props;
const isEs = lang === 'es';
const base = import.meta.env.BASE_URL;
---

<div id="cookie-consent" class="fixed bottom-0 left-0 right-0 z-50 p-4 translate-y-full transition-transform duration-700 ease-[cubic-bezier(0.32,0.72,0,1)]">
  <div class="max-w-3xl mx-auto glass rounded-2xl p-4 md:p-6 border border-border">
    <p class="text-sm leading-relaxed text-muted">
      {isEs
        ? 'Usamos cookies y tecnologías similares para mejorar tu experiencia, analizar el tráfico y mostrar contenido personalizado. Consulta nuestra'
        : 'We use cookies and similar technologies to improve your experience, analyze traffic, and show personalised content. See our'}
      <a href={`${base}${isEs ? '/es' : ''}/cookies`} class="text-gold underline hover:no-underline">{isEs ? 'Política de Cookies' : 'Cookie Policy'}</a>
      {isEs ? ' y nuestra' : ' and'}
      <a href={`${base}${isEs ? '/es' : ''}/privacy`} class="text-gold underline hover:no-underline">{isEs ? 'Política de Privacidad' : 'Privacy Policy'}</a>.
    </p>
    <div class="flex flex-wrap items-center gap-3 mt-4">
      <button id="cookie-accept" class="btn-primary !py-2 !px-5 !text-xs">
        {isEs ? 'Aceptar Todas' : 'Accept All'}
      </button>
      <button id="cookie-reject" class="btn-ghost !py-2 !px-5 !text-xs">
        {isEs ? 'Solo Necesarias' : 'Necessary Only'}
      </button>
    </div>
  </div>
</div>

<script>
  (function() {
    const banner = document.getElementById('cookie-consent');
    const acceptBtn = document.getElementById('cookie-accept');
    const rejectBtn = document.getElementById('cookie-reject');

    const consent = localStorage.getItem('cookie-consent');
    if (consent === 'accepted' || consent === 'rejected') {
      if (consent === 'accepted') {
        window.dispatchEvent(new CustomEvent('consent-granted'));
      }
      return;
    }

    requestAnimationFrame(() => {
      banner.style.transform = 'translateY(0)';
    });

    function setConsent(value) {
      localStorage.setItem('cookie-consent', value);
      banner.style.transform = 'translateY(100%)';
      if (value === 'accepted') {
        window.dispatchEvent(new CustomEvent('consent-granted'));
      }
    }

    acceptBtn.addEventListener('click', () => setConsent('accepted'));
    rejectBtn.addEventListener('click', () => setConsent('rejected'));
  })();
</script>
