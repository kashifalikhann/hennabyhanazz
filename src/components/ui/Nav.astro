---
const { lang = 'en' } = Astro.props;
const isEs = lang === 'es';
const t = (key: string) => isEs ? {
  'nav.gallery': 'Galería', 'nav.services': 'Servicios', 'nav.book': 'Reservar', 'nav.about': 'Sobre Mí', 'nav.gifts': 'Regalos', 'nav.mybooking': 'Mi Reserva'
}[key] || key : {
  'nav.gallery': 'Gallery', 'nav.services': 'Services', 'nav.book': 'Book', 'nav.about': 'About', 'nav.gifts': 'Gifts', 'nav.mybooking': 'My Booking'
}[key] || key;
const base = import.meta.env.BASE_URL;
---

<nav id="site-nav" class="fixed top-0 left-0 right-0 z-50 flex justify-center pt-4 transition-all duration-700 ease-[cubic-bezier(0.32,0.72,0,1)]" style="padding-top: calc(1rem + env(safe-area-inset-top, 0px))">
  <div class="glass flex items-center gap-6 rounded-full px-5 py-2.5 md:px-8 md:py-3 transition-all duration-700 ease-[cubic-bezier(0.32,0.72,0,1)]" id="nav-inner">
    <a href={base} class="font-display text-sm font-semibold tracking-tight whitespace-nowrap">
      <span class="text-gold">✦</span> Hanazz
    </a>

    <div class="hidden md:flex items-center gap-6" id="nav-links">
      <a href={`${base}${isEs ? '/es' : ''}/#gallery`} class="text-sm text-muted hover:text-text transition-colors duration-300">{t('nav.gallery')}</a>
      <a href={`${base}${isEs ? '/es' : ''}/#services`} class="text-sm text-muted hover:text-text transition-colors duration-300">{t('nav.services')}</a>
      <a href={`${base}${isEs ? '/es' : ''}/#about`} class="text-sm text-muted hover:text-text transition-colors duration-300">{t('nav.about')}</a>
      <a href={`${base}${isEs ? '/es' : ''}/gallery`} class="text-sm text-muted hover:text-text transition-colors duration-300 hidden lg:inline">{t('nav.gallery')}</a>
      <a href={`${base}${isEs ? '/es' : ''}/gift-certificate`} class="text-sm text-muted hover:text-text transition-colors duration-300 hidden lg:inline">{t('nav.gifts')}</a>
      <a href={`${base}${isEs ? '/es' : ''}/my-booking`} class="text-sm text-muted hover:text-text transition-colors duration-300 hidden lg:inline">{t('nav.mybooking')}</a>
      <a href={`${base}${isEs ? '/es/privacidad' : '/privacy'}`} class="text-sm text-muted hover:text-text transition-colors duration-300 hidden xl:inline">{isEs ? 'Privacidad' : 'Privacy'}</a>
      <a href={`${base}${isEs ? '/es/aviso-legal' : '/legal'}`} class="text-sm text-muted hover:text-text transition-colors duration-300 hidden xl:inline">{isEs ? 'Aviso Legal' : 'Legal'}</a>
      <a href={`${base}${isEs ? '/es' : ''}/book`} class="btn-primary !py-1.5 !px-4 !text-xs whitespace-nowrap">
        {t('nav.book')}
        <span class="icon-wrap !w-6 !h-6">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </span>
      </a>
    </div>

    <div class="flex items-center gap-2">
      <button aria-label={isEs ? 'Cambiar idioma' : 'Switch language'} id="lang-toggle" class="text-xs text-muted hover:text-text transition-colors duration-300 px-2 py-1 rounded-full border border-border">
        {isEs ? 'EN' : 'ES'}
      </button>

      <button aria-label="Toggle theme" id="theme-toggle" class="text-muted hover:text-text transition-colors duration-300 p-1.5">
        <svg class="dark-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
        <svg class="light-icon hidden" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
        </svg>
      </button>

      <button id="mobile-menu-btn" class="md:hidden flex flex-col items-center justify-center gap-1 w-11 h-11" aria-label="Menu">
        <span class="block w-5 h-[1.5px] bg-text transition-all duration-500 ease-[cubic-bezier(0.32,0.72,0,1)]"></span>
        <span class="block w-5 h-[1.5px] bg-text transition-all duration-500 ease-[cubic-bezier(0.32,0.72,0,1)]"></span>
        <span class="block w-5 h-[1.5px] bg-text transition-all duration-500 ease-[cubic-bezier(0.32,0.72,0,1)]"></span>
      </button>
    </div>
  </div>
</nav>

<div id="mobile-overlay" class="fixed inset-0 z-40 bg-black/80 backdrop-blur-3xl flex items-start justify-center pt-24 opacity-0 pointer-events-none transition-all duration-700 ease-[cubic-bezier(0.32,0.72,0,1)]">
  <div class="flex flex-col items-center gap-8 text-2xl font-display mt-8">
    <a href={`${base}${isEs ? '/es' : ''}/#gallery`} class="translate-y-12 opacity-0 transition-all duration-700 delay-100 mobile-link">{t('nav.gallery')}</a>
    <a href={`${base}${isEs ? '/es' : ''}/#services`} class="translate-y-12 opacity-0 transition-all duration-700 delay-150 mobile-link">{t('nav.services')}</a>
    <a href={`${base}${isEs ? '/es' : ''}/#about`} class="translate-y-12 opacity-0 transition-all duration-700 delay-200 mobile-link">{t('nav.about')}</a>
    <a href={`${base}${isEs ? '/es' : ''}/gallery`} class="translate-y-12 opacity-0 transition-all duration-700 delay-250 mobile-link">{t('nav.gallery')}</a>
    <a href={`${base}${isEs ? '/es' : ''}/gift-certificate`} class="translate-y-12 opacity-0 transition-all duration-700 delay-300 mobile-link">{t('nav.gifts')}</a>
    <a href={`${base}${isEs ? '/es' : ''}/my-booking`} class="translate-y-12 opacity-0 transition-all duration-700 delay-350 mobile-link">{t('nav.mybooking')}</a>
    <a href={`${base}${isEs ? '/es/privacidad' : '/privacy'}`} class="translate-y-12 opacity-0 transition-all duration-700 delay-400 mobile-link">{isEs ? 'Privacidad' : 'Privacy'}</a>
    <a href={`${base}${isEs ? '/es/aviso-legal' : '/legal'}`} class="translate-y-12 opacity-0 transition-all duration-700 delay-[450ms] mobile-link">{isEs ? 'Aviso Legal' : 'Legal'}</a>
    <a href={`${base}${isEs ? '/es' : ''}/book`} class="translate-y-12 opacity-0 transition-all duration-700 delay-500 mobile-link">{t('nav.book')}</a>
  </div>
</div>

<script>
  const nav = document.getElementById('site-nav');
  const navInner = document.getElementById('nav-inner');
  const themeToggle = document.getElementById('theme-toggle');
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileOverlay = document.getElementById('mobile-overlay');
  const mobileLinks = document.querySelectorAll('.mobile-link');
  const langToggle = document.getElementById('lang-toggle');

  let isOpen = false;

  window.addEventListener('scroll', () => {
    const scrolled = window.scrollY > 100;
    navInner.style.transform = scrolled ? 'scale(0.85)' : 'scale(1)';
    navInner.style.borderRadius = scrolled ? '9999px' : '9999px';
  });

  themeToggle?.addEventListener('click', () => {
    const isLight = document.documentElement.classList.toggle('light');
    localStorage.setItem('theme', isLight ? 'light' : 'dark');
    document.querySelector('.dark-icon')?.classList.toggle('hidden', isLight);
    document.querySelector('.light-icon')?.classList.toggle('hidden', !isLight);
  });

  if (localStorage.getItem('theme') === 'light') {
    document.documentElement.classList.add('light');
    document.querySelector('.dark-icon')?.classList.add('hidden');
    document.querySelector('.light-icon')?.classList.remove('hidden');
  }

  mobileBtn?.addEventListener('click', () => {
    isOpen = !isOpen;
    const bars = mobileBtn.querySelectorAll('span');
    if (isOpen) {
      mobileOverlay.classList.remove('opacity-0', 'pointer-events-none');
      bars[0].style.transform = 'rotate(45deg) translate(3px, 3px)';
      bars[1].style.opacity = '0';
      bars[2].style.transform = 'rotate(-45deg) translate(3px, -3px)';
      mobileLinks.forEach(l => { l.style.transform = 'translateY(0)'; l.style.opacity = '1'; });
    } else {
      mobileOverlay.classList.add('opacity-0', 'pointer-events-none');
      bars[0].style.transform = '';
      bars[1].style.opacity = '';
      bars[2].style.transform = '';
      mobileLinks.forEach(l => { l.style.transform = ''; l.style.opacity = ''; });
    }
  });

  mobileOverlay?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      isOpen = false;
      mobileOverlay.classList.add('opacity-0', 'pointer-events-none');
      const bars = mobileBtn.querySelectorAll('span');
      bars.forEach(b => { b.style.transform = ''; b.style.opacity = ''; });
      mobileLinks.forEach(l => { l.style.transform = ''; l.style.opacity = ''; });
    });
  });

  langToggle?.addEventListener('click', () => {
    const path = window.location.pathname;
    const base = import.meta.env.BASE_URL.replace(/\/$/, '');
    const esPrefix = base + '/es';
    if (path.startsWith(esPrefix)) {
      window.location.href = path.replace(esPrefix, base) || base;
    } else if (path === base + '/es') {
      window.location.href = base;
    } else {
      window.location.href = esPrefix + path.replace(base, '') || esPrefix;
    }
  });
</script>
