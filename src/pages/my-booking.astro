---
import BaseLayout from '../layouts/BaseLayout.astro';
const lang = 'en';
---

<BaseLayout title="My Booking" lang={lang}>
  <section class="pt-24 md:pt-32 pb-20 md:pb-24 px-6 min-h-screen">
    <div class="max-w-2xl mx-auto">
        <div class="text-center mb-10 md:mb-12">
        <span class="eyebrow">Booking</span>
        <h1 class="font-display text-3xl sm:text-4xl md:text-6xl font-bold tracking-tight mt-4">My Booking</h1>
        <p class="text-muted mt-4">Enter your email to look up your appointment details.</p>
      </div>
      <div class="bg-surface rounded-2xl border border-border p-4 md:p-8">
        <form class="space-y-4" method="GET">
          <input
            type="email"
            name="email"
            placeholder="Your email address"
            required
            class="w-full bg-bg border border-border rounded-xl px-4 py-3 text-text placeholder:text-muted focus:outline-none focus:border-gold transition-colors"
          />
          <button type="submit" class="btn-primary w-full justify-center">
            Find My Booking
            <span class="icon-wrap !w-6 !h-6">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </span>
          </button>
        </form>
        <p class="text-xs text-muted mt-4 text-center">
          We'll show your upcoming and past appointments linked to this email.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
