---
import BaseLayout from '../layouts/BaseLayout.astro';
const lang = 'en';
---

<BaseLayout title="404 — Page Not Found" lang={lang}>
  <section class="section-padding bg-cream text-center">
    <div class="container-premium max-w-lg">
      <h1 class="font-display text-8xl font-semibold text-gold mb-6">404</h1>
      <h2 class="font-display text-2xl font-semibold text-charcoal mb-4">Page Not Found</h2>
      <p class="text-gray mb-8">The page you are looking for does not exist or has been moved.</p>
      <a href="/" class="btn-primary">Back to Home</a>
    </div>
  </section>
</BaseLayout>
