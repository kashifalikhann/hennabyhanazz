---
import BaseLayout from '../layouts/BaseLayout.astro';
const lang = 'en';
const isEs = Astro.url.pathname.startsWith('/es');
const l = isEs ? 'es' : 'en';
---

<BaseLayout title={l === 'es' ? 'Página No Encontrada' : 'Page Not Found'} lang={l}>
  <section class="pt-24 md:pt-32 pb-20 md:pb-24 px-6 min-h-screen flex items-center justify-center">
    <div class="text-center max-w-lg">
      <span class="font-accent text-8xl md:text-9xl text-gold opacity-40">404</span>
      <h1 class="font-display text-3xl md:text-5xl font-bold tracking-tight mt-4">
        {l === 'es' ? 'Página No Encontrada' : 'Page Not Found'}
      </h1>
      <p class="text-muted mt-4">
        {l === 'es'
          ? 'La página que buscas no existe o ha sido movida.'
          : 'The page you are looking for does not exist or has been moved.'}
      </p>
      <a href={l === 'es' ? '/hennabyhanazz/es/' : '/hennabyhanazz/'} class="btn-primary mt-8 inline-flex">
        {l === 'es' ? 'Volver al Inicio' : 'Back to Home'}
        <span class="icon-wrap !w-6 !h-6">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </span>
      </a>
    </div>
  </section>
</BaseLayout>
