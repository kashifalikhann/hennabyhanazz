---
import BaseLayout from '../../layouts/BaseLayout.astro';
const lang = 'en';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Booking Confirmed" lang={lang}>
  <section class="pt-24 md:pt-32 pb-20 md:pb-24 px-6 min-h-screen flex items-center justify-center">
    <div class="text-center max-w-lg w-full" id="confirmation-content">
      <div class="w-16 h-16 rounded-full bg-green-500/20 flex items-center justify-center mx-auto mb-6">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5">
          <path d="M20 6L9 17l-5-5"/>
        </svg>
      </div>
      <h1 class="font-display text-3xl md:text-5xl font-bold tracking-tight" id="conf-title">Booking Confirmed!</h1>
      <p class="text-muted mt-4" id="conf-msg">Thank you! Your appointment is secured.</p>
      <div id="conf-details" class="mt-6 bg-surface rounded-xl p-6 border border-border text-left hidden"></div>
      <a href={base} class="btn-primary mt-8 inline-flex">
        Back to Home
        <span class="icon-wrap !w-6 !h-6">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </span>
      </a>
    </div>
  </section>
</BaseLayout>

<script>
  const details = document.getElementById('conf-details');
  const title = document.getElementById('conf-title');
  const msg = document.getElementById('conf-msg');

  try {
    const booking = JSON.parse(localStorage.getItem('hbnb_booking'));
    if (booking) {
      title.textContent = booking.lang === 'es' ? '¡Reserva Confirmada!' : 'Booking Confirmed!';
      if (booking.service === 'byod') {
        msg.innerHTML = booking.lang === 'es'
          ? 'Gracias ' + booking.name + '! Hanazz revisará tu diseño y te contactará para confirmar. Si tienes alguna pregunta, responde a tu correo de confirmación de Stripe.'
          : 'Thank you ' + booking.name + '! Hanazz will review your design and reach out to confirm. If you have questions, reply to your Stripe confirmation email.';
      } else {
        msg.textContent = booking.lang === 'es'
          ? 'Gracias ' + booking.name + '! Tu reserva está confirmada. Recibirás los detalles por correo.'
          : 'Thank you ' + booking.name + '! Your booking is confirmed. You\'ll receive details via email.';
      }

      details.classList.remove('hidden');
      const isEs = booking.lang === 'es';
      let byodHtml = '';
      if (booking.service === 'byod' && booking.designLink) {
        byodHtml = `
          <div class="flex justify-between py-2 border-b border-border">
            <span class="text-muted text-sm">${isEs ? 'Diseño' : 'Design'}</span>
            <span class="text-sm"><a href="${booking.designLink}" target="_blank" rel="noopener noreferrer" class="text-gold underline hover:no-underline">${isEs ? 'Ver archivo' : 'View file'}</a></span>
          </div>`;
        if (booking.notes) {
          byodHtml += `
          <div class="py-3 border-b border-border">
            <span class="text-muted text-sm block">${isEs ? 'Descripción' : 'Description'}</span>
            <p class="text-sm mt-1 leading-relaxed">${booking.notes}</p>
          </div>`;
        }
      }
      details.innerHTML = `
        <div class="flex justify-between py-2 border-b border-border">
          <span class="text-muted text-sm">${isEs ? 'Servicio' : 'Service'}</span>
          <span class="text-sm font-medium">${booking.serviceName}</span>
        </div>
        <div class="flex justify-between py-2 border-b border-border">
          <span class="text-muted text-sm">${isEs ? 'Fecha' : 'Date'}</span>
          <span class="text-sm">${booking.date}</span>
        </div>
        <div class="flex justify-between py-2 border-b border-border">
          <span class="text-muted text-sm">${isEs ? 'Hora' : 'Time'}</span>
          <span class="text-sm">${booking.time}</span>
        </div>
        <div class="flex justify-between py-2 border-b border-border">
          <span class="text-muted text-sm">Email</span>
          <span class="text-sm">${booking.email}</span>
        </div>
        ${byodHtml}
        <div class="flex justify-between py-2">
          <span class="text-muted text-sm">${isEs ? 'Código' : 'Code'}</span>
          <span class="text-sm font-mono text-gold font-bold">${booking.code}</span>
        </div>
      `;

      localStorage.removeItem('hbnb_booking');
    }
  } catch (e) {
    // no booking data, show default message
  }
</script>
