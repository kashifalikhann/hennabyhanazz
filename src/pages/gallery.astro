---
import BaseLayout from '../layouts/BaseLayout.astro';
import InstagramFeed from '../components/gallery/InstagramFeed.jsx';
const lang = 'en';
---

<BaseLayout title="Gallery" lang={lang}>
  <section class="pt-24 md:pt-32 pb-20 md:pb-24 px-6 min-h-screen">
    <div class="max-w-6xl mx-auto">
        <div class="text-center mb-10 md:mb-12">
        <span class="eyebrow">Portfolio</span>
        <h1 class="font-display text-3xl sm:text-4xl md:text-6xl font-bold tracking-tight mt-4">Our Work</h1>
        <p class="text-muted mt-3 md:mt-4 max-w-lg mx-auto">
          Each design tells a story. Browse our latest creations or follow <strong class="text-gold">@hennabyhanazz</strong> on Instagram for daily inspiration.
        </p>
      </div>
      <InstagramFeed client:load lang={lang} />
    </div>
  </section>
</BaseLayout>
