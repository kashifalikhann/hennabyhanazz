---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const lang = 'es';
---

<BaseLayout title="Pago Cancelado" lang={lang}>
  <section class="pt-24 md:pt-32 pb-20 md:pb-24 px-6 min-h-screen flex items-center justify-center">
    <div class="text-center max-w-lg">
      <div class="w-16 h-16 rounded-full bg-red-500/20 flex items-center justify-center mx-auto mb-6">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2.5">
          <path d="M18 6L6 18M6 6l12 12"/>
        </svg>
      </div>
      <h1 class="font-display text-3xl md:text-5xl font-bold tracking-tight">Pago Cancelado</h1>
      <p class="text-muted mt-4">No se realizó ningún cargo. Vuelve a intentarlo cuando quieras.</p>
      <a href="/hennabyhanazz/es/book" class="btn-primary mt-8 inline-flex">
        Intentar de Nuevo
        <span class="icon-wrap !w-6 !h-6">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </span>
      </a>
    </div>
  </section>
</BaseLayout>
