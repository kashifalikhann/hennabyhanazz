---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookingWidget from '../../components/booking/BookingWidget.jsx';
const lang = 'es';
---

<BaseLayout title="Reservar Cita" lang={lang}>
  <section class="pt-32 pb-24 px-6 min-h-screen">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <span class="eyebrow">Reserva</span>
        <h1 class="font-display text-4xl md:text-6xl font-bold tracking-tight mt-4">
          Reserva tu Cita
        </h1>
      </div>
      <BookingWidget client:only="react" lang={lang} />
    </div>
  </section>
</BaseLayout>
