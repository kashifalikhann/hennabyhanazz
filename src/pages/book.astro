---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookingWidget from '../components/booking/BookingWidget.jsx';
const lang = 'en';
---

<BaseLayout title="Book an Appointment" lang={lang}>
  <section class="pt-28 pb-16 px-6 min-h-screen">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <span class="eyebrow">{lang === 'es' ? 'Reserva' : 'Booking'}</span>
        <h1 class="font-display text-4xl md:text-6xl font-bold tracking-tight mt-4">
          {lang === 'es' ? 'Reserva tu Cita' : 'Book Your Appointment'}
        </h1>
      </div>
      <BookingWidget client:only="react" lang={lang} />
    </div>
  </section>
</BaseLayout>
