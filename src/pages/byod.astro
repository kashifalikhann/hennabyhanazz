---
import BaseLayout from '../layouts/BaseLayout.astro';
import { paymentLinks } from '../lib/payments';
const base = import.meta.env.BASE_URL;
const contactEmail = import.meta.env.PUBLIC_CONTACT_EMAIL;
const lang = 'en';
---

<BaseLayout title="Bring Your Own Design" lang={lang}>
  <section class="pt-28 pb-16 px-6 min-h-screen">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <span class="eyebrow">BYOD</span>
        <h1 class="font-display text-4xl md:text-6xl font-bold tracking-tight mt-4">Bring Your Own Design</h1>
        <p class="text-muted mt-4 max-w-2xl mx-auto leading-relaxed">
          Have a specific design in mind? Upload your concept, and Hanazz will bring it to life with 100% natural, PPD-free henna. Custom pieces start at €100.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 mb-16">
        <div class="bg-surface rounded-2xl p-6 border border-border">
          <div class="w-10 h-10 rounded-full bg-gold/20 flex items-center justify-center mb-4">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#C9A96E" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          </div>
          <h3 class="font-display font-semibold mb-2">Accepted File Types</h3>
          <p class="text-sm text-muted">JPG, PNG, PDF, SVG, AI, PSD</p>
        </div>
        <div class="bg-surface rounded-2xl p-6 border border-border">
          <div class="w-10 h-10 rounded-full bg-gold/20 flex items-center justify-center mb-4">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#C9A96E" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          </div>
          <h3 class="font-display font-semibold mb-2">Max File Size</h3>
          <p class="text-sm text-muted">10MB per file</p>
        </div>
        <div class="bg-surface rounded-2xl p-6 border border-border">
          <div class="w-10 h-10 rounded-full bg-gold/20 flex items-center justify-center mb-4">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#C9A96E" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          </div>
          <h3 class="font-display font-semibold mb-2">Review Time</h3>
          <p class="text-sm text-muted">Artist reviews within 48 hours</p>
        </div>
        <div class="bg-surface rounded-2xl p-6 border border-border">
          <div class="w-10 h-10 rounded-full bg-gold/20 flex items-center justify-center mb-4">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#C9A96E" stroke-width="2"><path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <h3 class="font-display font-semibold mb-2">Placement</h3>
          <p class="text-sm text-muted">Hand, arm, foot, or anywhere you choose</p>
        </div>
      </div>

      <div class="bg-surface rounded-2xl p-8 md:p-10 border border-border">
        <h2 class="font-display text-2xl md:text-3xl font-bold mb-8">Submit Your Design</h2>

        <form id="byod-form" class="space-y-5">
          <div class="grid md:grid-cols-2 gap-5">
            <input type="text" id="byod-name" required placeholder="Full Name"
              class="w-full bg-bg border border-border rounded-xl px-4 py-3 text-text placeholder:text-muted/50 focus:outline-none focus:border-gold transition-colors" />
            <input type="email" id="byod-email" required placeholder="Email Address"
              class="w-full bg-bg border border-border rounded-xl px-4 py-3 text-text placeholder:text-muted/50 focus:outline-none focus:border-gold transition-colors" />
          </div>
          <input type="tel" id="byod-phone" placeholder="Phone Number"
            class="w-full bg-bg border border-border rounded-xl px-4 py-3 text-text placeholder:text-muted/50 focus:outline-none focus:border-gold transition-colors" />

          <div class="grid md:grid-cols-2 gap-5">
            <div>
              <label class="text-sm text-muted block mb-2">Preferred Date</label>
              <input type="date" id="byod-date"
                min={new Date().toISOString().split('T')[0]}
                class="w-full bg-bg border border-border rounded-xl px-4 py-3 text-text focus:outline-none focus:border-gold transition-colors" />
            </div>
            <div>
              <label class="text-sm text-muted block mb-2">Preferred Time</label>
              <select id="byod-time"
                class="w-full bg-bg border border-border rounded-xl px-4 py-3 text-text focus:outline-none focus:border-gold transition-colors">
                <option value="">Select a time</option>
                <option value="10:00">10:00</option>
                <option value="11:00">11:00</option>
                <option value="12:00">12:00</option>
                <option value="14:00">14:00</option>
                <option value="15:00">15:00</option>
                <option value="16:00">16:00</option>
                <option value="17:00">17:00</option>
                <option value="18:00">18:00</option>
              </select>
            </div>
          </div>

          <div>
            <label class="text-sm text-muted block mb-2">Design Description</label>
            <textarea id="byod-description" required rows={4} placeholder="Describe your vision — style, colors, placement on body, occasion, any reference images you're attaching..."
              class="w-full bg-bg border border-border rounded-xl px-4 py-3 text-text placeholder:text-muted/50 focus:outline-none focus:border-gold transition-colors resize-none"></textarea>
          </div>

          <div>
            <label class="text-sm text-muted block mb-2">Upload Your Design Reference</label>
            <div class="border-2 border-dashed border-border rounded-xl p-8 text-center hover:border-gold/50 transition-colors cursor-pointer" id="upload-zone">
              <input type="file" id="byod-file" accept=".jpg,.jpeg,.png,.pdf,.svg,.ai,.psd" class="hidden" />
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mx-auto text-muted mb-3"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
              <p class="text-sm text-muted" id="upload-text">Click to upload or drag & drop</p>
              <p class="text-xs text-muted/50 mt-1">JPG, PNG, PDF, SVG, AI, PSD (max 10MB)</p>
            </div>
            <div id="upload-preview" class="hidden mt-3 p-3 rounded-xl bg-bg border border-border flex items-center gap-3"></div>
          </div>

          <label class="flex items-start gap-2 cursor-pointer pt-2">
            <input type="checkbox" id="byod-consent" required class="mt-0.5 shrink-0 accent-gold" />
            <span class="text-xs text-muted/70 leading-relaxed">
              I have read and agree to the <a href={`${base}/privacy`} target="_blank" rel="noopener noreferrer" class="text-gold underline hover:no-underline">Privacy Policy</a>. I understand the artist will review my design and confirm feasibility before finalising the booking.
            </span>
          </label>

          <button type="submit" id="byod-submit" class="btn-primary w-full justify-center text-base">
            <span id="byod-btn-text">Pay €100 & Submit Design</span>
            <span id="byod-btn-loading" class="hidden"><svg class="animate-spin" width="16" height="16" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" class="opacity-25"/><path d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z" fill="currentColor" class="opacity-75"/></svg></span>
            <span class="icon-wrap !w-6 !h-6"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg></span>
          </button>
        </form>

        <div id="byod-success" class="hidden text-center py-8">
          <div class="w-16 h-16 rounded-full bg-green-500/20 flex items-center justify-center mx-auto mb-6">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
          </div>
          <h3 class="font-display text-2xl font-bold">Design Submitted!</h3>
          <p class="text-muted mt-2">Redirecting to payment...</p>
        </div>
      </div>

      <div class="mt-16">
        <h2 class="font-display text-2xl md:text-3xl font-bold text-center mb-10">How It Works</h2>
        <div class="grid md:grid-cols-4 gap-6">
          <div class="text-center">
            <div class="w-12 h-12 rounded-full bg-gold text-bg flex items-center justify-center mx-auto mb-4 font-display font-bold text-lg">1</div>
            <h3 class="font-display font-semibold mb-2">Submit Design</h3>
            <p class="text-sm text-muted">Upload your reference image and describe your vision</p>
          </div>
          <div class="text-center">
            <div class="w-12 h-12 rounded-full bg-gold/20 text-gold flex items-center justify-center mx-auto mb-4 font-display font-bold text-lg">2</div>
            <h3 class="font-display font-semibold mb-2">Artist Review</h3>
            <p class="text-sm text-muted">Hanazz reviews your design within 48 hours</p>
          </div>
          <div class="text-center">
            <div class="w-12 h-12 rounded-full bg-gold/20 text-gold flex items-center justify-center mx-auto mb-4 font-display font-bold text-lg">3</div>
            <h3 class="font-display font-semibold mb-2">Confirmation</h3>
            <p class="text-sm text-muted">You receive approval + appointment confirmation via email</p>
          </div>
          <div class="text-center">
            <div class="w-12 h-12 rounded-full bg-gold/20 text-gold flex items-center justify-center mx-auto mb-4 font-display font-bold text-lg">4</div>
            <h3 class="font-display font-semibold mb-2">Your Session</h3>
            <p class="text-sm text-muted">Come to the studio and get your custom henna</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const dropZone = document.getElementById('upload-zone');
  const fileInput = document.getElementById('byod-file');
  const uploadText = document.getElementById('upload-text');
  const uploadPreview = document.getElementById('upload-preview');
  const form = document.getElementById('byod-form');
  const submitBtn = document.getElementById('byod-submit');
  const btnText = document.getElementById('byod-btn-text');
  const btnLoading = document.getElementById('byod-btn-loading');
  const successDiv = document.getElementById('byod-success');
  const contactEmail = document.getElementById('byod-form').dataset.email || 'info@smgtec.es';

  let uploadedFile = null;
  let uploadUrl = null;

  dropZone.addEventListener('click', () => fileInput.click());

  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('border-gold');
  });
  dropZone.addEventListener('dragleave', () => {
    dropZone.classList.remove('border-gold');
  });
  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('border-gold');
    if (e.dataTransfer.files.length) handleFile(e.dataTransfer.files[0]);
  });
  fileInput.addEventListener('change', () => {
    if (fileInput.files.length) handleFile(fileInput.files[0]);
  });

  function handleFile(file) {
    if (file.size > 10 * 1024 * 1024) {
      alert('File too large. Maximum size is 10MB.');
      return;
    }
    uploadedFile = file;
    uploadText.textContent = file.name;
    uploadPreview.classList.remove('hidden');
    uploadPreview.innerHTML = `
      <span class="text-xs text-muted truncate flex-1">${file.name} (${(file.size / 1024 / 1024).toFixed(1)}MB)</span>
      <button type="button" id="remove-file" class="text-xs text-red-400 hover:text-red-300">Remove</button>
    `;
    document.getElementById('remove-file')?.addEventListener('click', () => {
      uploadedFile = null;
      uploadText.textContent = 'Click to upload or drag & drop';
      uploadPreview.classList.add('hidden');
      fileInput.value = '';
    });
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const name = document.getElementById('byod-name').value.trim();
    const email = document.getElementById('byod-email').value.trim();
    const phone = document.getElementById('byod-phone').value.trim();
    const date = document.getElementById('byod-date').value;
    const time = document.getElementById('byod-time').value;
    const description = document.getElementById('byod-description').value.trim();
    const consent = document.getElementById('byod-consent').checked;

    if (!name || !email || !description || !consent) {
      alert('Please fill in all required fields and accept the Privacy Policy.');
      return;
    }

    btnText.classList.add('hidden');
    btnLoading.classList.remove('hidden');
    submitBtn.disabled = true;

    let designLink = '';
    if (uploadedFile) {
      try {
        const fd = new FormData();
        fd.append('file', uploadedFile);
        const res = await fetch('https://file.io', { method: 'POST', body: fd });
        const data = await res.json();
        if (data.success) designLink = data.link;
      } catch (err) {
        console.error('Upload failed:', err);
      }
    }

    const code = 'HBH-' + Math.random().toString(36).substring(2, 8).toUpperCase();
    const booking = { service: 'byod', serviceName: 'BYOD', date, time, name, email, phone, notes: description, code, designLink, lang: 'en' };
    localStorage.setItem('hbnb_booking', JSON.stringify(booking));

    successDiv.classList.remove('hidden');
    form.classList.add('hidden');

    setTimeout(() => {
      window.location.href = 'https://buy.stripe.com/test_3cIcN56665Ojgdk2Sm3gk06';
    }, 1500);
  });
</script>
