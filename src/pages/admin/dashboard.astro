---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdminDashboard from '../../components/admin/AdminDashboard.jsx';
const lang = 'en';
---

<BaseLayout title="Admin Dashboard" lang={lang}>
  <section class="pt-24 md:pt-32 pb-20 md:pb-24 px-6 min-h-screen">
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-6 md:mb-8">
        <div>
          <h1 class="font-display text-2xl sm:text-3xl md:text-5xl font-bold tracking-tight">Admin Dashboard</h1>
          <p class="text-muted mt-1">Manage bookings, services, and gift certificates.</p>
        </div>
      </div>
      <AdminDashboard client:only="react" lang={lang} />
    </div>
  </section>
</BaseLayout>
